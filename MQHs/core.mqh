enum coreModeOption
  {
   up,
   down,
   consolidation,
   save_up,
   save_down
  };
enum coreForceOption
  {
   low,
   medium,
   high
  };
input coreModeOption coreMode = consolidation; //Core Mode
input coreForceOption coreForce = medium; //Core Force